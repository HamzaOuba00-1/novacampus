# ============================================================
# Environnement d'exécution
# ============================================================
NODE_ENV=dev

# ============================================================
# Serveur Express
#   auth-service          : 3001
#   academic-service      : 3002
#   planning-service      : 3003
#   inscription-service   : 3004
#   payment-service       : 3005
#   notification-service  : 3006
#   campus-service        : 3007
#   reporting-service     : 3008
# ============================================================
API_PORT=3008

# ============================================================
# JSON Web Token – même secret que l'auth-service
# ============================================================
JWT_SECRET=novacampus_dev_secret_change_in_production_openssl_rand_base64_32

# ============================================================
# Base de données PostgreSQL
# ============================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=novacampus_reporting

# ============================================================
# URLs des microservices sources de données
# Le reporting agrège les données de tous les autres services
# ============================================================
ACADEMIC_SERVICE_URL=http://academic-service:3002
PAYMENT_SERVICE_URL=http://payment-service:3005
INSCRIPTION_SERVICE_URL=http://inscription-service:3004
PLANNING_SERVICE_URL=http://planning-service:3003
CAMPUS_SERVICE_URL=http://campus-service:3007
NOTIFICATION_SERVICE_URL=http://notification-service:3006

# ============================================================
# Agent IA – seuils de détection
# ============================================================
AI_DROPOUT_RISK_THRESHOLD=0.65
AI_PAYMENT_RISK_THRESHOLD=0.70
AI_LOW_ATTENDANCE_THRESHOLD=0.50
AI_ANALYSIS_BATCH_SIZE=50

# ============================================================
# Rafraîchissement du cache KPI (minutes)
# ============================================================
KPI_CACHE_TTL_MINUTES=60
