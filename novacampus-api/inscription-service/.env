# ============================================================
# Environnement d'exécution
# ============================================================
NODE_ENV=dev

# ============================================================
# Serveur Express
#   auth-service        : 3001
#   academic-service    : 3002
#   planning-service    : 3003
#   inscription-service : 3004
# ============================================================
API_PORT=3004

# ============================================================
# JSON Web Token – même secret que l'auth-service
# ============================================================
JWT_SECRET=novacampus_dev_secret_change_in_production_openssl_rand_base64_32

# ============================================================
# Base de données PostgreSQL – base dédiée aux inscriptions
# En Docker  : DB_HOST = nom du service dans compose.yml
# En local   : DB_HOST = localhost
# ============================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=novacampus_inscription

# ============================================================
# Stockage des documents étudiants (pièces justificatives)
# En dev : stockage local dans /uploads
# En prod : remplacer par S3 / MinIO
# ============================================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
