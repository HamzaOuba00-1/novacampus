# ============================================================
# Environnement d'exécution
# ============================================================
NODE_ENV=dev

# ============================================================
# Serveur Express
#   auth-service          : 3001
#   academic-service      : 3002
#   planning-service      : 3003
#   inscription-service   : 3004
#   payment-service       : 3005
#   notification-service  : 3006
#   campus-service        : 3007
# ============================================================
API_PORT=3007

# ============================================================
# JSON Web Token – même secret que l'auth-service
# ============================================================
JWT_SECRET=novacampus_dev_secret_change_in_production_openssl_rand_base64_32

# ============================================================
# Base de données PostgreSQL
# En Docker  : DB_HOST = nom du service dans compose.yml
# En local   : DB_HOST = localhost
# ============================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=novacampus_campus

# ============================================================
# Rétention de l'audit log (jours)
# Les entrées plus anciennes sont archivées (pas supprimées)
# ============================================================
AUDIT_LOG_RETENTION_DAYS=365
