# ============================================================
# Environnement d'exécution
# ============================================================
NODE_ENV=dev

# ============================================================
# Serveur Express
#   auth-service        : 3001
#   academic-service    : 3002
#   planning-service    : 3003
#   inscription-service : 3004
#   payment-service     : 3005
# ============================================================
API_PORT=3005

# ============================================================
# JSON Web Token – même secret que l'auth-service
# ============================================================
JWT_SECRET=novacampus_dev_secret_change_in_production_openssl_rand_base64_32

# ============================================================
# Base de données PostgreSQL – base dédiée aux paiements
# En Docker  : DB_HOST = nom du service dans compose.yml
# En local   : DB_HOST = localhost
# ============================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=novacampus_payment

# ============================================================
# Configuration des relances automatiques
# REMINDER_LEVEL1_DAYS : jours après échéance pour la relance niveau 1
# REMINDER_LEVEL2_DAYS : jours après échéance pour la relance niveau 2
# REMINDER_LEVEL3_DAYS : jours après échéance pour la relance niveau 3
# ============================================================
REMINDER_LEVEL1_DAYS=7
REMINDER_LEVEL2_DAYS=15
REMINDER_LEVEL3_DAYS=30

# ============================================================
# URL du service inscriptions pour synchroniser le paymentStatus
# Utilisé après enregistrement d'un paiement
# ============================================================
INSCRIPTION_SERVICE_URL=http://inscription-service:3004
