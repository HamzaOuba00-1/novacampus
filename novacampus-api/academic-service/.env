# ============================================================
# Environnement d'exécution
# Valeurs possibles : dev | test | prod
# ============================================================
NODE_ENV=dev

# ============================================================
# Serveur Express
# Port distinct de l'auth-service (3001)
# ============================================================
API_PORT=3002

# ============================================================
# JSON Web Token – même secret que l'auth-service
# Le service académique vérifie les tokens émis par l'auth-service
# Ne JAMAIS différer de la valeur dans auth-service/.env
# ============================================================
JWT_SECRET=novacampus_dev_secret_change_in_production_openssl_rand_base64_32

# ============================================================
# Base de données PostgreSQL – base dédiée au service académique
# En Docker  : DB_HOST = nom du service dans compose.yml
# En local   : DB_HOST = localhost
# ============================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=novacampus_academic

# ============================================================
# Stockage des fichiers (ressources pédagogiques)
# En dev : stockage local dans /uploads
# En prod : remplacer par une URL S3 / MinIO
# ============================================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=20
