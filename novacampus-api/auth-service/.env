# ============================================================
# Environnement d'exécution
# Valeurs possibles : dev | test | prod
# ============================================================
NODE_ENV=dev

# ============================================================
# Serveur Express
# ============================================================
API_PORT=3001

# ============================================================
# Hachage des mots de passe (bcrypt)
# Minimum recommandé : 12 en production
# ============================================================
SALT_ROUNDS=12

# ============================================================
# JSON Web Token
# JWT_SECRET : générer avec : openssl rand -base64 32
# JWT_EXPIRES_IN : durée de vie du token d'accès (ex: 15m, 1h)
# JWT_REFRESH_SECRET : secret distinct pour les refresh tokens
# JWT_REFRESH_EXPIRES_IN : durée de vie du refresh token (ex: 7d)
# ============================================================
JWT_SECRET=novacampus_dev_secret_change_in_production_openssl_rand_base64_32
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=novacampus_refresh_secret_change_in_production
JWT_REFRESH_EXPIRES_IN=7d

# ============================================================
# Base de données PostgreSQL
# En Docker : DB_HOST = nom du service dans compose.yml
# En local  : DB_HOST = localhost
# ============================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=novacampus_auth