# ============================================================
# Environnement d'exécution
# Valeurs possibles : dev | test | prod
# ============================================================
NODE_ENV=dev

# ============================================================
# Serveur Express – port distinct des autres services
#   auth-service     : 3001
#   academic-service : 3002
#   planning-service : 3003
# ============================================================
API_PORT=3003

# ============================================================
# JSON Web Token – même secret que l'auth-service
# Le planning-service vérifie les tokens émis par l'auth-service
# Ne JAMAIS différer de la valeur dans auth-service/.env
# ============================================================
JWT_SECRET=novacampus_dev_secret_change_in_production_openssl_rand_base64_32

# ============================================================
# Base de données PostgreSQL – base dédiée au service planning
# En Docker  : DB_HOST = nom du service dans compose.yml
# En local   : DB_HOST = localhost
# ============================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=novacampus_planning
