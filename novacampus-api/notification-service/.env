# ============================================================
# Environnement d'exécution
# ============================================================
NODE_ENV=dev

# ============================================================
# Serveur Express + WebSocket
#   auth-service          : 3001
#   academic-service      : 3002
#   planning-service      : 3003
#   inscription-service   : 3004
#   payment-service       : 3005
#   notification-service  : 3006
# ============================================================
API_PORT=3006

# ============================================================
# JSON Web Token – même secret que l'auth-service
# ============================================================
JWT_SECRET=novacampus_dev_secret_change_in_production_openssl_rand_base64_32

# ============================================================
# Base de données PostgreSQL
# ============================================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=novacampus_notification

# ============================================================
# WebSocket
# Durée (ms) entre deux pings keepalive pour détecter les
# connexions mortes
# ============================================================
WS_PING_INTERVAL_MS=30000

# ============================================================
# Email (simulation en dev – remplacer par SMTP réel en prod)
# ============================================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@novacampus.fr
SMTP_PASS=change_me_in_production
EMAIL_FROM=Novacampus <no-reply@novacampus.fr>

# ============================================================
# SMS (simulation en dev – remplacer par Twilio/OVH en prod)
# ============================================================
SMS_PROVIDER=simulation
SMS_FROM=NOVACAMPUS
